{
  "name": "@codeatlas/vscode",
  "version": "0.1.0",
  "displayName": "CodeAtlas",
  "description": "Interactive code knowledge graph for VSCode - visualize architecture, search semantically, analyze impact",
  "publisher": "codeatlas",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Visualization", "Other"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsc -p .",
    "dev": "tsc -w -p .",
    "package": "vsce package",
    "clean": "rm -rf dist"
  },
  "contributes": {
    "commands": [
      {
        "command": "codeatlas.scan",
        "title": "Scan Project",
        "icon": "$(refresh)"
      },
      {
        "command": "codeatlas.search",
        "title": "Search Symbols",
        "icon": "$(search)"
      },
      {
        "command": "codeatlas.showGraph",
        "title": "Open Graph View",
        "icon": "$(graph)"
      },
      {
        "command": "codeatlas.analyzeImpact",
        "title": "Analyze Impact",
        "icon": "$(warning)"
      },
      {
        "command": "codeatlas.explainFile",
        "title": "Explain Current File",
        "icon": "$(info)"
      },
      {
        "command": "codeatlas.showLayers",
        "title": "Show Architecture Layers",
        "icon": "$(list-flat)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeatlas",
          "title": "CodeAtlas",
          "icon": "$(graph)"
        }
      ]
    },
    "views": {
      "codeatlas": [
        {
          "id": "codeatlas.structureView",
          "name": "Code Structure",
          "icon": "$(symbol-class)"
        },
        {
          "id": "codeatlas.layersView",
          "name": "Architecture Layers",
          "icon": "$(list-flat)"
        },
        {
          "id": "codeatlas.graphView",
          "name": "Graph View",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "codeatlas.analyzeImpact",
          "when": "editorHasSelection",
          "group": "codeatlas"
        }
      ],
      "commandPalette": [
        { "command": "codeatlas.scan", "when": "workspaceFolderCount > 0" },
        { "command": "codeatlas.search", "when": "workspaceFolderCount > 0" },
        { "command": "codeatlas.showGraph", "when": "workspaceFolderCount > 0" },
        { "command": "codeatlas.analyzeImpact", "when": "editorHasSelection" },
        { "command": "codeatlas.explainFile", "when": "editorIsOpen" },
        { "command": "codeatlas.showLayers", "when": "workspaceFolderCount > 0" }
      ]
    }
  },
  "dependencies": {
    "@codeatlas/core": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
